{
  "mcpServers": {
    "aws-diagram-mcp-server": {
      "command": "uvx",
      "args": [
        "awslabs.aws-diagram-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "autoApprove": [
        "list_icons",
        "generate_diagram"
      ],
      "disabled": false
    }
  }
}